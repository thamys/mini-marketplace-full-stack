{
  "name": "mini-marketplace-full-stack",
  "version": "1.0.0",
  "main": "github-import_2.js",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"pnpm -C frontend dev\" \"pnpm -C backend dev\"",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:format": "pnpm -C backend exec prisma format",
    "db:migrate": "pnpm -C backend exec prisma migrate dev",
    "db:generate": "pnpm -C backend exec prisma generate",
    "db:studio": "pnpm -C backend exec prisma studio",
    "db:reset": "pnpm -C backend exec prisma migrate reset",
    "db:deploy": "pnpm -C backend exec prisma migrate deploy"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thamys/mini-marketplace-full-stack.git"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
